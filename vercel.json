{
  "crons": [
    {
      "path": "/api/calendar/cleanup",
      "schedule": "0 */1 * * *"
    },
    {
      "path": "/api/reminder",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "pages/api/calendar/cleanup.js": {
      "maxDuration": 300
    },
    "pages/api/reminder.js": {
      "maxDuration": 60
    }
  }
}